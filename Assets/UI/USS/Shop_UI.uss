    margin-top: 13px;
    margin-right: 13px;
    margin-bottom: 13px;
    margin-left: 13px;
    border-top-left-radius: 54px;
}

.mode-desc {
    -unity-text-align: lower-center;
    font-size: 21px;
    align-self: center;
    translate: 0 121px;
    margin-top: 25px;
    margin-right: 25px;
    margin-bottom: 25px;
    margin-left: 25px;
    white-space: pre-wrap;
    text-overflow: ellipsis;
}

.indie-container {
    flex-direction: column;
    align-items: center;
    display: flex;
    width: 589px;
    height: 685px;
    margin-top: 27px;
    margin-right: 27px;
    margin-bottom: 27px;
