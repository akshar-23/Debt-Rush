    font-size: 35px;
    margin-top: -14px;
    margin-right: -14px;
    margin-bottom: -14px;
    margin-left: -14px;
}

.obj-button {
    width: 533px;
    align-self: center;
    margin-top: 13px;
    margin-right: 13px;
    margin-bottom: 13px;
    margin-left: 13px;
    flex-basis: 0;
    flex-grow: 1;
    flex-direction: row;
}

.obj-container {
    flex-grow: 1;
    justify-content: center;
    align-items: auto;
    align-content: auto;
    margin-top: 20px;
    margin-right: 20px;
    margin-bottom: 20px;
    margin-left: 20px;
}

.hint-box {
    flex-grow: 0;
    width: 89px;
